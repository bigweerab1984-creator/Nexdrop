# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git. NEVER put these keys in frontend code.

# --- CJ Dropshipping ---
# Get from: CJ Dropshipping app -> Setting -> Account -> API Setting -> Generate API Keys
# Format looks like: CJUserNum@api@xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CJ_API_KEY=your_cj_api_key_here

# --- Stripe ---
# Get from: stripe.com -> Developers -> API Keys (use TEST keys while building)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# --- Database (Vercel Postgres / Neon) ---
# Get from: Vercel dashboard -> Storage -> Create Postgres database
# It auto-fills these when you connect the DB to your project
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# --- Site config ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEFAULT_MARKUP_MULTIPLIER=2.5
